RewriteEngine On
RewriteBase /

# -----------------------------
# 1. API → BACKEND/API
# -----------------------------
RewriteRule ^api/(.*)$ backend/api/$1 [L,QSA]

# -----------------------------
# 2. Laisser passer fichiers existants (PHP, assets, etc.)
# -----------------------------
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# -----------------------------
# 3. React fallback
# -----------------------------
RewriteRule . /index.html [L]